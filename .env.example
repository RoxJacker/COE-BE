# Variables de entorno — COE Zapopan Backend
# Copia este archivo como .env y llena los valores

PORT=3000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<usuario>:<password>@clustercoe.sbk9law.mongodb.net/coe-zapopan?appName=ClusterCOE

# JWT — genera con: [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(64))
JWT_SECRET=reemplaza_con_tu_secreto_generado
JWT_EXPIRES_IN=8h

# CORS — origen del frontend
CLIENT_URL=http://localhost:5173

# Telegram Bot (configurar en Sprint 2)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
